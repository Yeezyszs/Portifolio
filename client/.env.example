# URL da API Express.
# Em desenvolvimento, deixe VAZIO: o Vite faz proxy de /api para localhost:3333.
# Em produção (front e back em domínios diferentes), coloque a URL absoluta.
VITE_API_URL=

# Supabase — pegue em: Project Settings > API
# anon key é segura para o browser (sujeita às RLS policies)
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6...
